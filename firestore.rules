rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) 
        && data.keys().size() >= 4 && data.keys().size() <= 10
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && (data.get('displayName', '') is string)
        && (data.get('photoURL', '') is string)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'ownerId', 'status', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 5 && data.keys().size() <= 10
        && data.title is string && data.title.size() <= 256
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.status in ['Draft', 'Live', 'Final', 'Archived']
        && (data.get('description', '') is string)
        && (data.get('img', '') is string)
        && (data.get('data', {}) is map)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // --- Collections ---

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId);
      allow list: if false; // Blanket user list is forbidden
      
      allow create: if isUserVerified() 
        && userId == request.auth.uid 
        && isValidId(userId)
        && incoming().uid == userId
        && isValidUser(incoming());

      allow update: if isUserVerified() 
        && userId == request.auth.uid 
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
      
      allow delete: if false; // Users cannot be deleted via client
    }

    // Projects Collection
    match /projects/{projectId} {
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      allow create: if isUserVerified()
        && isValidId(projectId)
        && incoming().ownerId == request.auth.uid
        && isValidProject(incoming());

      allow update: if isUserVerified()
        && existing().ownerId == request.auth.uid
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Edit metadata
          (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'updatedAt'])) ||
          // Action: Save design data
          (incoming().diff(existing()).affectedKeys().hasOnly(['data', 'updatedAt'])) ||
          // Action: Change status
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
          // Action: Update image
          (incoming().diff(existing()).affectedKeys().hasOnly(['img', 'updatedAt']))
        )
        && isValidProject(incoming());

      allow delete: if isUserVerified() 
        && existing().ownerId == request.auth.uid;
    }
  }
}
